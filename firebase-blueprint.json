{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "semesterStartDate": { "type": "string", "format": "date", "description": "The start date of the current semester" },
        "aiName": { "type": "string", "description": "Custom name for the AI assistant" },
        "aiPersonality": { "type": "string", "description": "Custom personality for the AI assistant" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Course": {
      "title": "Course",
      "description": "A scheduled course in the campus assistant",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "location": { "type": "string" },
        "dayOfWeek": { "type": "number", "description": "0-6 (Sun-Sat)" },
        "startTime": { "type": "string", "description": "HH:mm format" },
        "endTime": { "type": "string", "description": "HH:mm format" },
        "weeks": { "type": "array", "items": { "type": "number" }, "description": "List of weeks this course is active" },
        "color": { "type": "string" }
      },
      "required": ["userId", "name", "dayOfWeek", "startTime", "endTime"]
    },
    "Todo": {
      "title": "Todo",
      "description": "A task or assignment for the user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "completed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A message in the AI chat history",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "role", "content", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/users/{userId}/courses/{courseId}": {
      "schema": "Course",
      "description": "User's course schedule"
    },
    "/users/{userId}/todos/{todoId}": {
      "schema": "Todo",
      "description": "User's todo list"
    },
    "/users/{userId}/chatHistory/{messageId}": {
      "schema": "ChatMessage",
      "description": "User's AI chat history"
    }
  }
}
